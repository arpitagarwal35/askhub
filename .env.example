# ─── Google Cloud / Vertex AI ─────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_LLM_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=gemini-embedding-001

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=              # set if your Qdrant instance requires auth
QDRANT_COLLECTION=team-default

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
API_KEY=change-me-to-a-strong-random-key   # required in production; omit to disable auth in dev
ALLOWED_ORIGINS=http://localhost:5173   # comma-separated for multiple origins

# ─── Confluence ───────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=you@your-org.com
CONFLUENCE_API_TOKEN=your-confluence-api-token

# ─── Jira (optional) ─────────────────────────────────────────────────────────
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@your-org.com
# JIRA_API_TOKEN=your-jira-token
# JIRA_PROJECT_KEY=MYPROJECT

# ─── SharePoint / Microsoft Graph (optional) ─────────────────────────────────
# SHAREPOINT_TENANT_ID=your-tenant-id
# SHAREPOINT_CLIENT_ID=your-client-id
# SHAREPOINT_CLIENT_SECRET=your-client-secret
# SHAREPOINT_SITE_ID=your-site-id
